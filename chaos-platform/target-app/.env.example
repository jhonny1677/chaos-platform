# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=target-app
APP_VERSION=1.0.0
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# For local dev: start postgres with docker run -e POSTGRES_PASSWORD=chaos
#                -e POSTGRES_USER=chaos -e POSTGRES_DB=chaos_platform
#                -p 5432:5432 postgres:15
DATABASE_URL=postgresql+asyncpg://chaos:chaos@localhost:5432/chaos_platform
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_ECHO=false

# ── Observability ──────────────────────────────────────────────────────────────
# Leave blank to disable OTLP export (dev mode — spans are discarded)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=target-app

# ── Kubernetes downward API (set automatically by pod spec, not manually) ──────
POD_NAME=local-dev
POD_NAMESPACE=target-app
NODE_NAME=local-node

# ── Streaming ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*
