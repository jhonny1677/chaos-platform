{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "SLO compliance dashboard — availability, error budget, burn rate",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Platform Overview", "url": "/d/chaos-platform-overview", "type": "link" }
  ],
  "refresh": "60s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["chaos-platform", "slo"],
  "title": "SLO Dashboard",
  "uid": "slo-dashboard",
  "version": 1,
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Current Availability (30 days)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 99.0 },
              { "color": "green",  "value": 99.5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - job:http_error_ratio:rate30d) * 100",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Error Budget Remaining",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green",  "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job:slo_error_budget_remaining:ratio * 100",
          "legendFormat": "Budget Remaining",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "SLO Target",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "text": { "valueSize": 48 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "vector(99.5)",
          "legendFormat": "SLO Target",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error Budget Burn Rate (1h / 6h windows)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "short",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Fast Burn Threshold (14×)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 5], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Slow Burn Threshold (3×)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 5], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job:http_error_ratio:rate1h / 0.005",
          "legendFormat": "Burn Rate (1h)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "job:http_error_ratio:rate6h / 0.005",
          "legendFormat": "Burn Rate (6h)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "vector(14)",
          "legendFormat": "Fast Burn Threshold (14×)",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "vector(3)",
          "legendFormat": "Slow Burn Threshold (3×)",
          "refId": "D"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "30-Day Availability Trend",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "options": {
        "legend": { "calcs": ["min", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "percent",
          "min": 98,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 99.0 },
              { "color": "green",  "value": 99.5 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO Target (99.5%)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 5], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - job:http_error_ratio:rate30d) * 100",
          "legendFormat": "Availability",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "vector(99.5)",
          "legendFormat": "SLO Target (99.5%)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Daily SLO Compliance",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "options": { "showHeader": true },
      "fieldConfig": {
        "defaults": { "custom": { "align": "center", "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Availability %" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "decimals", "value": 3 },
              { "id": "unit", "value": "percent" },
              { "id": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red",    "value": null },
                    { "color": "yellow", "value": 99.0 },
                    { "color": "green",  "value": 99.5 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "SLO Met" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "mappings", "value": [
                  { "type": "value", "options": { "Yes": { "color": "green", "index": 0 } } },
                  { "type": "value", "options": { "No":  { "color": "red",   "index": 1 } } }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - sum_over_time(job:http_error_ratio:rate5m[1d]) / count_over_time(job:http_error_ratio:rate5m[1d])) * 100",
          "legendFormat": "",
          "refId": "A",
          "instant": false,
          "format": "table",
          "step": 86400
        }
      ],
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "alias": "SLO Met",
            "mode": "reduceRow",
            "binary": {
              "left": "Value",
              "right": "99.5",
              "operator": ">="
            }
          }
        }
      ]
    }
  ]
}
